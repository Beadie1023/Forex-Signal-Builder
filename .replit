modules = ["nodejs-24", "python-base-3.13"]

    [[ports]]
    localPort = 8080
    externalPort = 80

    [deployment]
    router = "application"
    deploymentTarget = "autoscale"

    [deployment.postBuild]
    args = ["pnpm", "store", "prune"]
    env = { "CI" = "true" }

    [workflows]
    runButton = "Project"

    [[workflows.workflow]]
    name = "Project"
    mode = "parallel"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "workflow.run"
    args = "GBP/AUD Signal App"

    [[workflows.workflow]]
    name = "GBP/AUD Signal App"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "cd forex-signals && streamlit run app.py"
    waitForPort = 8080

    [workflows.workflow.metadata]
    outputType = "webview"

    [agent]
    stack = "PNPM_WORKSPACE"
    expertMode = true

    [postMerge]
    path = "scripts/post-merge.sh"
    timeoutMs = 20000

    [nix]
    channel = "stable-25_05"
    packages = ["glibcLocales"]
    